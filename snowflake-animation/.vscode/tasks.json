{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Компиляция Java",
            "type": "shell",
            "command": "javac",
            "args": [
                "-cp",
                "processing/core.jar",
                "-d",
                "out",
                "src/SnowflakesAnimation.java"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Запуск Java",
            "type": "shell",
            "command": "java",
            "args": [
                "-cp",
                "processing/core.jar;out",
                "SnowflakesAnimation"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            }
        }
    ]
}
